# ── Backend API ──────────────────────────────────────────────────────────────
# Base URL of the Steady Vitality backend. Used server-side by the
# /api/assessment route to forward leads. If left unset, the assessment is
# only logged (the landing keeps working without a backend).
API_URL=http://localhost:3001

# ── Cal.com booking ─────────────────────────────────────────────────────────
# Cal.com event link (username/event) embedded in the appointment section.
NEXT_PUBLIC_CAL_LINK=jhonda/30min
# Arbitrary namespace identifier for the Cal.com embed instance.
NEXT_PUBLIC_CAL_NAMESPACE=coaching

# ── Optional ─────────────────────────────────────────────────────────────────
# Google Analytics measurement ID.
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
